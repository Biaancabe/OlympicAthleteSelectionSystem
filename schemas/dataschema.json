{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "CompetitionResults",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "Date": {
                "type": "string",
                "format": "date",
                "description": "Event date in YYYY-MM-DD"
            },
            "Year": {
                "type": "integer",
                "minimum": 1800,
                "maximum": 2100
            },
            "Comp.SetDetail": {
                "type": "string"
            },
            "Sport": {
                "type": "string"
            },
            "Discipline": {
                "type": "string"
            },
            "Gender": {
                "type": "string",
                "description": "e.g., Male, Female, Mixed"
            },
            "Class": {
                "type": "string",
                "enum": [
                    "Seniors",
                    "Juniors",
                    "Under 23"
                ]
                        },
            "Team Members": {
                "type": "string",
                "enum": [
                    "Yes",
                    "No"
                ]
            },
            "Person/Team": {
              "type": [
                    "string",
                    "null"
                ]
            },
            "DoB": {
                "type": [
                    "string",
                    "null"
                ],
                "format": "date",
                "description": "Date of birth in YYYY-MM-DD or null if unknown"
            },
            "source": {
                "type": "string",
                "enum": [
                    "podium_csv",
                    "manual_csv",
                    "manual_form"
                ],
                "description": "Origin of the record for traceability"
            },
            "Rank_num": {
                "type": [
                    "integer",
                    "null"
                ],
                "minimum": 1,
                "description": "Cleaned numeric rank; null if DNF/DNQ/DNS/DSQ or missing"
            },
            "Rank_Status": {
                "type": [
                    "string",
                    "null"
                ],
                "enum": [
                    "DNF",
                    "DNQ",
                    "DNS",
                    "DSQ",
                    null
                ],
                "description": "Non-standard result status; null for a normal placement"
            },
            "Result_num": {
                "type": [
                    "number",
                    "null"
                ],
                "description": "Cleaned numeric performance value (time/points/distance); null if DNF/DNQ/DNS/DSQ or missing"
            },
            "Result_Status": {
                "type": [
                    "string",
                    "null"
                ],
                "enum": [
                    "DNF",
                    "DNQ",
                    "DNS",
                    "DSQ",
                    null
                ],
                "description": "Non-standard result status for the performance value; null if normal"
            },
            "Is Olympic Discipline": {
                "type": [
                    "boolean",
                    "null"
                ],
                "description": "True if Olympic discipline, False if not, null if unknown"
            }
        },
        "additionalProperties": false
    }
}